{
  "$description": "Atelier default design system — DTCG (Design Tokens Community Group) format. Source of truth for the Style Dictionary fan-out to CSS / Tailwind / Swift / Kotlin (AT-050). Per-tenant systems override this at runtime (AT-053).",
  "color": {
    "$type": "color",
    "primary": { "$value": "#2563eb", "$description": "Primary brand / action color" },
    "primary-hover": { "$value": "#1d4ed8" },
    "on-primary": { "$value": "#ffffff" },
    "surface": { "$value": "#ffffff" },
    "surface-muted": { "$value": "#f8fafc" },
    "border": { "$value": "#e2e8f0" },
    "text": { "$value": "#0f172a", "$description": "Default body text" },
    "text-muted": { "$value": "#475569" },
    "success": { "$value": "#16a34a" },
    "warning": { "$value": "#d97706" },
    "danger": { "$value": "#dc2626" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Inter", "system-ui", "sans-serif"] },
      "mono": { "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "12px" },
      "sm": { "$value": "14px" },
      "base": { "$value": "16px" },
      "lg": { "$value": "20px" },
      "xl": { "$value": "24px" },
      "2xl": { "$value": "32px" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "bold": { "$value": 700 }
    }
  },
  "space": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "40px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "16px" },
    "full": { "$value": "9999px" }
  }
}
