{
  "name": "brief_parser_llm",
  "description": "Extracts a structured BriefSpec from validated brief text; schema-constrained (no free-form system prompt).",
  "version": "0.2.0a0",
  "protocolVersion": "0.3.0",
  "url": "https://atelier.autonomous-agent.dev/.well-known/agents/intake_brief_parser/agent-card.json",
  "provider": {
    "organization": "Manzela",
    "url": "https://manzela.com"
  },
  "skills": [
    {
      "id": "brief-parsing",
      "name": "Brief Parsing",
      "description": "Extracts a structured BriefSpec from raw brief text; schema-constrained (output_schema=BriefSpec).",
      "inputModes": ["text"],
      "outputModes": ["text"],
      "tags": ["intake", "brief", "schema-extraction"]
    }
  ],
  "protocols": {
    "a2a": "0.3.0",
    "adk": "2.1"
  },
  "authentication": {
    "schemes": [
      {
        "type": "bearer",
        "description": "Firebase ID token from Identity Platform"
      },
      {
        "type": "apiKey",
        "description": "API key for service-to-service communication",
        "in": "header",
        "name": "X-Atelier-API-Key"
      }
    ]
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "stateTransitionHistory": true,
    "multiTurn": false
  },
  "defaultInputModes": ["text"],
  "defaultOutputModes": ["text"]
}
