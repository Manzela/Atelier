{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "singleProjectMode": true,
    "ui": {
      "enabled": false
    }
  },
  "hosting": [
    {
      "site": "atelier-build-2026",
      "public": "docs/dashboards",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": [
        "firebase.json",
        "**/.git/**",
        "**/.DS_Store",
        "**/.env",
        "**/.env.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-XSS-Protection", "value": "1; mode=block" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
            { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self' https://www.gstatic.com/firebasejs/ https://apis.google.com https://www.gstatic.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/ https://www.recaptcha.net/ https://static.cloudflareinsights.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.googleusercontent.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://identitytoolkit.googleapis.com https://accounts.google.com https://www.google.com/recaptcha/ https://recaptcha.net/ https://*.us-central1.run.app https://*.autonomous-agent.dev https://cloudflareinsights.com; frame-src 'self' https://*.firebaseapp.com https://apis.google.com https://accounts.google.com https://www.google.com/recaptcha/ https://recaptcha.google.com/recaptcha/ https://www.recaptcha.net/; frame-ancestors 'none';"
            }
          ]
        },
        {
          "source": "**/*.{js,css,woff2,png,jpg,svg}",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "config.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "**/*.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        }
      ],
      "redirects": [
        {
          "source": "/auth",
          "destination": "/login",
          "type": 302
        },
        {
          "source": "/docs/limits",
          "destination": "/docs#governance",
          "type": 301
        }
      ],
      "rewrites": [
        {
          "source": "/health",
          "run": {
            "serviceId": "atelier-api-production",
            "region": "us-central1"
          }
        },
        {
          "source": "/.well-known/agent-card.json",
          "run": {
            "serviceId": "atelier-api-production",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/**",
          "run": {
            "serviceId": "atelier-api-production",
            "region": "us-central1"
          }
        },
        {
          "source": "/v1/**",
          "run": {
            "serviceId": "atelier-api-production",
            "region": "us-central1"
          }
        },
        {
          "source": "/studio/**",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/board",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/board/**",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/login",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/_next/**",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        }
      ]
    },
    {
      "target": "dashboard",
      "public": "docs/dashboards",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": [
        "firebase.json",
        "**/.git/**",
        "**/.DS_Store",
        "**/.env",
        "**/.env.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-XSS-Protection", "value": "1; mode=block" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
            { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self' https://www.gstatic.com/firebasejs/ https://apis.google.com https://www.gstatic.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/ https://www.recaptcha.net/ https://static.cloudflareinsights.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.googleusercontent.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://identitytoolkit.googleapis.com https://accounts.google.com https://www.google.com/recaptcha/ https://recaptcha.net/ https://*.us-central1.run.app https://*.autonomous-agent.dev https://cloudflareinsights.com; frame-src 'self' https://*.firebaseapp.com https://apis.google.com https://accounts.google.com https://www.google.com/recaptcha/ https://recaptcha.google.com/recaptcha/ https://www.recaptcha.net/; frame-ancestors 'none';"
            }
          ]
        },
        {
          "source": "**/*.{js,css,woff2,png,jpg,svg}",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "config.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "**/*.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        }
      ],
      "redirects": [
        {
          "source": "/auth",
          "destination": "/login",
          "type": 302
        },
        {
          "source": "/docs/limits",
          "destination": "/docs#governance",
