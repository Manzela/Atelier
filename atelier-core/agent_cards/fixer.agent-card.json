{
  "name": "atelier_fixer",
  "description": "Analyzes gate failures and low axis scores and proposes a FixerDirective (mutations + prompt amendments) for the next iteration.",
  "version": "0.2.0a0",
  "protocolVersion": "0.3.0",
  "url": "https://atelier.autonomous-agent.dev/.well-known/agents/fixer/agent-card.json",
  "provider": {
    "organization": "Manzela",
    "url": "https://manzela.com"
  },
  "skills": [
    {
      "id": "fix-directive",
      "name": "Fix Directive",
      "description": "Analyzes gate failures and low axis scores; proposes a FixerDirective (mutations + prompt amendments) for the next iteration.",
      "inputModes": ["text"],
      "outputModes": ["text"],
      "tags": ["fixer", "iteration", "gate-failure"]
    }
  ],
  "protocols": {
    "a2a": "0.3.0",
    "adk": "2.1"
  },
  "authentication": {
    "schemes": [
      {
        "type": "bearer",
        "description": "Firebase ID token from Identity Platform"
      },
      {
        "type": "apiKey",
        "description": "API key for service-to-service communication",
        "in": "header",
        "name": "X-Atelier-API-Key"
      }
    ]
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "stateTransitionHistory": true,
    "multiTurn": false
  },
  "defaultInputModes": ["text"],
  "defaultOutputModes": ["text"]
}
