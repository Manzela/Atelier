# Atelier — .gitattributes
# Auto-detect text files, normalize line endings, configure LFS for binaries

* text=auto eol=lf

# Source code
*.py text diff=python
*.pyi text diff=python
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.jsonc text
*.yml text
*.yaml text
*.toml text
*.html text diff=html
*.css text
*.scss text
*.md text
*.txt text
*.sh text eol=lf
*.bash text eol=lf
Dockerfile* text
Makefile text
*.tf text
*.tfvars text

# Binary assets — Git LFS
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text

# Model weights — Git LFS
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.lora filter=lfs diff=lfs merge=lfs -text

# Generated files — exclude from diffs
*.lock linguist-generated=true
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
poetry.lock linguist-generated=true
requirements.lock linguist-generated=true
bun.lockb linguist-generated=true binary

# Vendored / generated docs
docs/site/** linguist-vendored=true
*.min.js linguist-generated=true
*.min.css linguist-generated=true

# Forced binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Playwright visual-regression reference snapshots: store as normal binary git
# blobs (NOT Git LFS), so CI checkout — which does not fetch LFS — gets the real
# PNG bytes instead of a 130-byte LFS pointer (otherwise toHaveScreenshot fails
# with "Could not decode expected image as PNG"). These references are tiny (~37KB).
atelier-dashboard/e2e/**/*.png -filter -diff -merge binary
