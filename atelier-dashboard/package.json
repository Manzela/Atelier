{
  "name": "atelier-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit --strict",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:lighthouse": "npx -y @lhci/cli@0.15.1 autorun",
    "test:bundle": "ANALYZE=true next build",
    "test:all": "npm run typecheck && npm run lint && npm run test:e2e",
    "validate": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "@a2ui/markdown-it": "0.0.4",
    "@a2ui/react": "0.10.0",
    "firebase": "^12.13.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@next/bundle-analyzer": "^16.2.6",
    "postcss": "^8.5.10",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
