# EditorConfig — https://editorconfig.org
# Atelier — consistent formatting across editors

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown line-break syntax requires trailing spaces
max_line_length = off

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
end_of_line = lf

[*.{html,css,scss}]
indent_size = 2

[Dockerfile*]
indent_size = 2
