            "region": "us-central1"
          }
        },
        {
          "source": "/api/**",
          "run": {
            "serviceId": "atelier-api-staging",
            "region": "us-central1"
          }
        },
        {
          "source": "/v1/**",
          "run": {
            "serviceId": "atelier-api-staging",
            "region": "us-central1"
          }
        },
        {
          "source": "/studio/**",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/board",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/board/**",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/login",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/_next/**",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        },
        {
          "source": "/",
          "run": {
            "serviceId": "atelier-dashboard",
            "region": "us-central1"
          }
        }
      ]
    }
  ]
}
