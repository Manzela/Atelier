{
  "name": "@atelier/workspace",
  "version": "0.1.0-alpha",
  "description": "Atelier — autonomous design agent (workspace root, npm workspaces config)",
  "private": true,
  "license": "Apache-2.0",
  "author": "Daniel Manzela <hello@atelier.dev>",
  "homepage": "https://atelier.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Manzela/atelier.git"
  },
  "bugs": {
    "url": "https://github.com/Manzela/atelier/issues"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "atelier-dashboard",
    "atelier-action",
    "atelier-figma-plugin",
    "atelier-chrome-extension"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "clean": "rm -rf node_modules .turbo .next out dist build",
    "prepare": "test -d .git && (pre-commit install --install-hooks || true) || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.8.0",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "endOfLine": "lf",
    "arrowParens": "always",
    "bracketSpacing": true
  }
}
