# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/test-results/
/playwright-report/
e2e-results.json
# Exclude platform-specific snapshots written locally (darwin/win32); only Linux refs are committed
e2e/**/*-darwin.png
e2e/**/*-win32.png
# Explicitly allow Linux snapshot references generated in CI
!e2e/**/*-linux.png
e2e/__artifacts__/
