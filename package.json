{
  "name": "@atelier/workspace",
  "version": "0.2.0-alpha",
  "description": "Atelier — autonomous design agent (workspace root, npm workspaces config)",
  "private": true,
  "license": "Apache-2.0",
  "author": "Daniel Manzela <Manzela@users.noreply.github.com>",
  "homepage": "https://atelier.autonomous-agent.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Manzela/atelier.git"
  },
  "bugs": {
    "url": "https://github.com/Manzela/atelier/issues"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "atelier-dashboard"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "clean": "rm -rf node_modules .turbo .next out dist build",
    "build:tokens": "node design-tokens/build-tokens.mjs",
    "lhci": "npx -y @lhci/cli@0.15.1 autorun --config=./lighthouserc.json",
    "prepare": "test -d .git && (pre-commit install --install-hooks || true) || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.11.0",
    "firebase-tools": "^15.18.0",
    "prettier": "^3.3.3",
    "style-dictionary": "^4.4.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "zod": "3.25.76",
    "gaxios": {
      "uuid": "^11.1.1"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "endOfLine": "lf",
    "arrowParens": "always",
    "bracketSpacing": true
  }
}
