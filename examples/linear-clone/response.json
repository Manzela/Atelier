  "best_candidate": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Active Issues - Acme Corp</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n    <style>:root{--c-auto-0:rgba(0,0,0,0.3);--c-auto-1:#2A2D33;--c-auto-2:#4A5568;}\n        /* --- DESIGN SYSTEM TOKENS --- */\n        :root {\n            /* Color Tokens */\n            --color-background-canvas: #0d0e10;\n            --color-background-surface-1: #121317;\n            --color-background-surface-2: #191a1d;\n            --color-background-interactive-hover: #1d1e22;\n            --color-background-overlay-light: rgba(255, 255, 255, 0.2);\n            --color-text-primary: #f0f0f1;\n            --color-text-secondary: #a0a2a7;\n            --color-text-tertiary: #676a70;\n            --color-text-on-accent: #ffffff;\n            --color-border-default: #23252a;\n            --color-border-subtle: #303136;\n            --color-accent-primary: #5e6ad2;\n            --color-accent-primary-hover: #6975dd;\n            --color-interactive-focus-ring: #727ee5;\n            --color-status-todo: #a0a2a7;\n            --color-status-in-progress: #d19f4f;\n            --color-status-done: #5ead7a;\n            --color-priority-urgent: #e96464;\n            --color-priority-high: #e28946;\n            --color-priority-medium: #d19f4f;\n            --color-priority-low: #5692f3;\n\n            /* Typography Tokens */\n            --typography-font-family-sans: 'Inter', sans-serif;\n            --typography-size-heading: 24px;\n            --typography-size-body-default: 14px;\n            --typography-size-body-compact: 13px;\n            --typography-size-label-default: 12px;\n            --typography-size-label-compact: 11px;\n            --typography-weight-regular: 400;\n            --typography-weight-medium: 500;\n            --typography-weight-semibold: 600;\n\n            /* Spacing Tokens */\n            --spacing-1: 1px;\n            --spacing-2: 2px;\n            --spacing-4: 4px;\n            --spacing-5: 5px;\n            --spacing-6: 6px;\n            --spacing-8: 8px;\n            --spacing-10: 10px;\n            --spacing-12: 12px;\n            --spacing-16: 16px;\n            --spacing-24: 24px;\n            --spacing-50: 50px;\n            --spacing-240: 240px;\n            --spacing-negative-8: -8px;\n\n            /* Radius Tokens */\n            --radius-xs: 2px;\n            --radius-sm: 4px;\n            --radius-md: 5px;\n            --radius-lg: 6px;\n            --radius-xl: 12px;\n            --radius-full: 50%;\n\n            /* Elevation Tokens */\n            --elevation-flyout: 0px 4px 12px 0px rgba(0,0,0,0.3);\n        }\n\n        /* --- BASE & UTILITIES --- */\n        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n        html {\n            font-family: var(--typography-font-family-sans);\n            font-size: var(--typography-size-body-default);\n            color: var(--color-text-primary);\n            background-color: var(--color-background-canvas);\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n        body { overflow: hidden; }\n        .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0; }\n        *:focus-visible { outline: var(--spacing-2) solid var(--color-interactive-focus-ring); outline-offset: var(--spacing-2); border-radius: var(--radius-sm); }\n        .icon { width: 16px; height: 16px; flex-shrink: 0; }\n\n        /* --- GLOBAL LAYOUT [S-1] --- */\n        .app-container { display: grid; grid-template-columns: var(--spacing-240) 1fr; height: 100vh; }\n\n        /* --- LEFT SIDEBAR (NAV) [S-1.1] --- */\n        .app-nav {\n            background-color: var(--color-background-surface-1);\n            border-right: var(--spacing-1) solid var(--color-border-default);\n            display: flex; flex-direction: column;\n            padding: var(--spacing-12); gap: var(--spacing-16);\n            overflow-y: auto;\n        }\n\n        .workspace-section { /* [S-1.1.1] */\n            display: flex; align-items: center;\n            gap: var(--spacing-8); padding: var(--spacing-4);\n        }\n        .workspace-avatar { width: var(--spacing-24); height: var(--spacing-24); border-radius: var(--radius-sm); background-color: #2A2D33; /* Placeholder */ }\n        .workspace-name { font-weight: var(--typography-weight-medium); flex-grow: 1; }\n        .notification-btn { background: none; border: none; color: var(--color-text-secondary); cursor: pointer; position: relative; padding: var(--spacing-4); }\n        .notification-dot { position: absolute; top: var(--spacing-4); right: var(--spacing-4); width: var(--spacing-6); height: var(--spacing-6); border-radius: var(--radius-full); background-color: var(--color-accent-primary); border: var(--spacing-1) solid var(--color-background-surface-1); }\n\n        .new-issue-btn { /* [S-1.1.2] */\n            display: flex; align-items: center; justify-content: center;\n            gap: var(--spacing-8); width: 100%;\n            padding: var(--spacing-8) var(--spacing-12);\n            background-color: var(--color-accent-primary);\n            color: var(--color-text-on-accent);\n            border: none; border-radius: var(--radius-lg);\n            font-weight: var(--typography-weight-medium);\n            font-size: var(--typography-size-body-default);\n            cursor: pointer; transition: background-color 150ms ease;\n        }\n        .new-issue-btn:hover { background-color: var(--color-accent-primary-hover); }\n        .shortcut-key { background-color: var(--color-background-overlay-light); padding: var(--spacing-2) var(--spacing-5); border-radius: var(--radius-sm); font-size: var(--typography-size-label-default); font-weight: var(--typography-weight-semibold); }\n\n        .nav-group { /* [S-1.1.3, S-1.1.4, S-1.1.5] */\n            display: flex; flex-direction: column; gap: var(--spacing-4);\n        }\n        .nav-group-title {\n            font-size: var(--typography-size-label-compact); font-weight: var(--typography-weight-semibold); color: var(--color-text-tertiary);\n            padding: 0 var(--spacing-8) var(--spacing-4); text-transform: uppercase;\n        }\n        .nav-list { list-style: none; }\n        .nav-item a {\n            display: flex; align-items: center; gap: var(--spacing-8);\n            padding: var(--spacing-6) var(--spacing-8); border-radius: var(--radius-md);\n            color: var(--color-text-secondary); text-decoration: none;\n            font-size: var(--typography-size-body-default);\n            transition: background-color 150ms ease, color 150ms ease;\n        }\n        .nav-item a .icon { color: var(--color-text-tertiary); transition: color 150ms ease; }\n        .nav-item a:hover { background-color: var(--color-background-interactive-hover); color: var(--color-text-primary); }\n        .nav-item a:hover .icon { color: var(--color-text-secondary); }\n        .nav-item a[aria-current=\"page\"] { background-color: var(--color-background-surface-2); color: var(--color-text-primary); font-weight: var(--typography-weight-medium); }\n        .nav-item a[aria-current=\"page\"] .icon { color: var(--color-text-primary); }\n\n        /* --- CENTER PANE (MAIN) [S-1.2] --- */\n        .app-main { display: flex; flex-direction: column; overflow: hidden; padding: var(--spacing-16) var(--spacing-24); }\n\n        .view-header { /* [S-1.2.1] */\n            font-size: var(--typography-size-heading); font-weight: var(--typography-weight-semibold); padding-bottom: var(--spacing-12);\n        }\n\n        .view-toolbar { /* [S-1.2.2] */\n            display: flex; align-items: center; gap: var(--spacing-8);\n            padding-bottom: var(--spacing-12); flex-shrink: 0; border-bottom: var(--spacing-1) solid var(--color-border-default);\n        }\n        .toolbar-btn { /* [S-1.2.2.1, S-1.2.2.2] */\n            display: inline-flex; align-items: center; gap: var(--spacing-6);\n            background-color: var(--color-background-surface-2); border: var(--spacing-1) solid var(--color-border-subtle);\n            color: var(--color-text-secondary); padding: var(--spacing-5) var(--spacing-10); border-radius: var(--radius-lg);\n            font-size: var(--typography-size-body-compact); cursor: pointer;\n            transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;\n        }\n        .toolbar-btn:hover { background-color: var(--color-background-interactive-hover); color: var(--color-text-primary); border-color: var(--color-border-subtle); }\n        .toolbar-btn .icon { width: 14px; height: 14px; }\n\n        .active-filters { /* [S-1.2.2.4] */ display: flex; align-items: center; gap: var(--spacing-8); list-style: none; }\n        .filter-chip {\n            display: flex; align-items: center; gap: var(--spacing-6);\n            background-color: var(--color-background-surface-2); padding: var(--spacing-4) var(--spacing-8); border-radius: var(--radius-xl);\n            font-size: var(--typography-size-body-compact); color: var(--color-text-primary);\n        }\n        .filter-chip-dismiss {\n            background: none; border: none; color: var(--color-text-tertiary);\n            cursor: pointer; padding: var(--spacing-2); display: inline-flex;\n            align-items: center; justify-content: center; border-radius: var(--radius-full);\n        }\n        .filter-chip-dismiss:hover { color: var(--color-text-primary); background-color: var(--color-background-interactive-hover); }\n        \n        /* --- ISSUES LIST [S-1.2.3] --- */\n        .issues-list { overflow-y: auto; flex-grow: 1; }\n        .issue-group-header { /* [S-1.2.3.1] */\n            font-size: var(--typography-size-label-default); font-weight: var(--typography-weight-medium);\n            color: var(--color-text-secondary); padding: var(--spacing-16) var(--spacing-8) var(--spacing-8);\n        }\n        .issue-row { /* [S-1.2.3.2] */\n            display: flex; align-items: center; padding: var(--spacing-8);\n            border-bottom: var(--spacing-1) solid var(--color-border-default);\n            gap: var(--spacing-12); cursor: pointer; position: relative; transition: background-color 150ms ease;\n        }\n        .issue-row:hover, .issue-row:focus-within { background-color: var(--color-background-interactive-hover); }\n        .issue-row:focus-within { outline: none; }\n        .issue-row:focus-within::before {\n            content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;\n            border: var(--spacing-2) solid var(--color-interactive-focus-ring);\n            border-radius: var(--radius-sm); pointer-events: none;\n        }\n        \n        .issue-select input[type=\"checkbox\"] { /* [S-1.2.3.2.1] */\n            -webkit-appearance: none; appearance: none; width: 16px; height: 16px;\n            border: var(--spacing-1) solid var(--color-border-subtle); border-radius: var(--radius-sm);\n            background-color: var(--color-background-surface-1); cursor: pointer; display: grid; place-content: center;\n        }\n        .issue-select input[type=\"checkbox\"]::before {\n            content: ''; width: 8px; height: 8px; transform: scale(0);\n            transition: 120ms transform ease-in-out;\n            background-color: var(--color-accent-primary); border-radius: var(--radius-xs);\n        }\n        .issue-select input[type=\"checkbox\"]:checked::before { transform: scale(1); }\n        .issue-select input[type=\"checkbox\"]:focus-visible { outline-offset: var(--spacing-1); }\n\n        .issue-status { /* [S-1.2.3.2.2] */ flex-shrink: 0; display: flex; align-items: center; gap: var(--spacing-6); font-size: var(--typography-size-body-compact); }\n        .issue-id { /* [S-1.2.3.2.3] */ flex-shrink: 0; color: var(--color-text-secondary); font-size: var(--typography-size-body-compact); }\n        .issue-title { /* [S-1.2.3.2.4] */ flex-grow: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n        .issue-metadata { display: flex; align-items: center; gap: var(--spacing-12); flex-shrink: 0; }\n        .issue-priority-icon { /* [S-1.2.3.2.6] */ display: flex; align-items: center; }\n        .issue-assignees { /* [S-1.2.3.2.5] */ display: flex; align-items: center; }\n        .assignee-avatar {\n            width: var(--spacing-20); height: var(--spacing-20); border-radius: var(--radius-full);\n            border: var(--spacing-2) solid var(--color-background-canvas); background-color: #4A5568; /* Placeholder */\n        }\n        .assignee-avatar:not(:first-child) { margin-left: var(--spacing-negative-8); }\n        .issue-timestamp { /* [S-1.2.3.2.7] */ color: var(--color-text-secondary); font-size: var(--typography-size-body-compact); width: var(--spacing-50); text-align: right; }\n        \n        .shortcut-hint { /* [S-1.2.3.2.8] */\n            position: absolute; right: var(--spacing-8); top: 50%; transform: translateY(-50%);\n            background-color: var(--color-background-surface-2); color: var(--color-text-primary);\n            padding: var(--spacing-4) var(--spacing-8); border-radius: var(--radius-sm);\n            border: var(--spacing-1) solid var(--color-border-subtle);\n            font-size: var(--typography-size-label-default);\n            opacity: 0; pointer-events: none; transition: opacity 150ms ease;\n            box-shadow: var(--elevation-flyout);\n        }\n        .issue-row:hover .shortcut-hint, .issue-row:focus-within .shortcut-hin