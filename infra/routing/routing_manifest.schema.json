{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atelier.autonomous-agent.dev/schemas/routing-manifest-v1.0.json",
  "title": "Atelier Routing Manifest",
  "description": "Schema for infra/routing/manifest.yaml — validates the phase-aware MoE router configuration (ADR 0027, §13.1 gate g10).",
  "type": "object",
  "required": ["version", "router_version", "phases", "fallback_chains", "experts"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "router_version": {
      "type": "string",
      "enum": ["v0_managed", "v1_bandit", "v2_matrix_factorization"]
    },
    "pricing_source": {
      "type": "string"
    },
    "phases": {
      "type": "object",
      "minProperties": 8,
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["primary_expert", "rationale", "budget_sensitive"],
          "properties": {
            "primary_expert": {
              "type": "string"
            },
            "rationale": {
              "type": "string",
              "minLength": 10
            },
            "budget_sensitive": {
              "type": "boolean"
            },
            "budget_floor_usd": {
              "type": "number",
              "minimum": 0
            },
            "low_budget_expert": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "if": {
            "properties": { "budget_sensitive": { "const": true } }
          },
          "then": {
            "required": ["budget_floor_usd", "low_budget_expert"]
          }
        }
      },
      "additionalProperties": false
    },
    "fallback_chains": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^.+$": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "cost_usd_per_1k_input_tokens"],
        "properties": {
          "id": { "type": "string" },
          "cost_usd_per_1k_input_tokens": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  }
}
