{
  "manifest_version": 3,
  "name": "Atelier — Redesign Any Web Page",
  "version": "0.1.0",
  "description": "Right-click any web page → 'Redesign with Atelier'. Side-by-side comparison of original vs converged design.",
  "author": "Daniel Manzela",
  "homepage_url": "https://atelier.dev",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Atelier — Redesign this page"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "https://api.atelier.dev/*",
    "https://atelier.dev/*"
  ],
  "options_page": "src/options.html"
}
